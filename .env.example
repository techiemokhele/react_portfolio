# ── Server-side (Vercel env vars — NEVER prefix with VITE_) ──────────────────
# Gmail SMTP credentials (used by /api/send-email serverless function)
#
# GMAIL_USER: your Gmail address
# GMAIL_APP_PASSWORD: 16-char App Password from Google Account > Security
#   Requires 2-Step Verification to be enabled on the Gmail account.
#   Steps: myaccount.google.com > Security > 2-Step Verification > App Passwords
#   Select "Mail" as the app, copy the generated 16-char password.
GMAIL_USER=neomokhele23@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Client-side (VITE_ prefix — bundled into the JS, safe to expose) ─────────
# reCAPTCHA v3 site key
# Get it at: https://www.google.com/recaptcha/admin/create
# Choose reCAPTCHA v3, add domains: localhost + your Vercel URL
VITE_RECAPTCHA_SITE_KEY=6LeXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# reCAPTCHA v3 SECRET key (server-side verification — keep secret)
# From the same reCAPTCHA console page as the site key above.
RECAPTCHA_SECRET_KEY=6LeXXXXXXXXXXXXXXXXXXXXXXXXXXXX
