# ── EmailJS ───────────────────────────────────────────────────────────────────
# Get these from https://www.emailjs.com
# Dashboard > Account > General = Public Key
# Dashboard > Email Services = Service ID
# Dashboard > Email Templates = Template IDs (create two: admin + confirmation)

VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_ADMIN_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_CONFIRM_TEMPLATE_ID=template_xxxxxxx

# ── Google reCAPTCHA v3 ────────────────────────────────────────────────────────
# Get a free site key at https://www.google.com/recaptcha/admin/create
# Choose reCAPTCHA v3, add your domain (localhost + vercel URL)

VITE_RECAPTCHA_SITE_KEY=6LeXXXXXXXXXXXXXXXXXXXX

# ── (Legacy / fallback) ────────────────────────────────────────────────────────
VITE_WEB3FORMS_KEY=your_web3forms_key
